---
// Consent banner with a real choice, not just a notice. Shows once, stores
// the visitor's choice in localStorage, and never shows again once a
// choice has been made.
//
// No ad script or ad-related cookie is loaded until the visitor clicks
// Accept (see loadAdsScripts() below, and its call sites). Clicking Reject
// keeps the site fully functional, just without personalized ads.
//
// AdSense ultimately requires a certified consent management platform (CMP)
// for EEA/UK visitors. This custom banner is the interim solution only.
// Once the AdSense account exists, use the native Privacy & Messaging tool
// in the AdSense dashboard to deploy a fully certified CMP banner site-wide,
// which replaces this component rather than running alongside it. That
// tool issues its own script tag to add to BaseLayout.astro's <head>, e.g.:
//
// <script async src="https://fundingchoicesmessages.google.com/i/YOUR_PUB_ID?ers=1"></script>
// <script>(function() {function signalGooglefcPresent() {if (!window.frames['googlefcPresent']) {if (document.body) {const iframe = document.createElement('iframe'); iframe.style = 'width:0;height:0;border:none;z-index:-1000;left:-1000px;top:-1000px;'; iframe.style.display = 'none'; iframe.name = 'googlefcPresent'; document.body.appendChild(iframe);} else {setTimeout(signalGooglefcPresent, 0);}}} signalGooglefcPresent();})();</script>
---

<div class="cookie-banner" id="cookie-banner" hidden>
  <div class="cookie-banner-inner">
    <p>
      We use cookies to run this site and keep it free.
      <a href="/privacy-policy/">Privacy Policy</a>
    </p>
    <div class="cookie-banner-actions">
      <button class="btn btn-secondary" id="cookie-reject" type="button">Reject</button>
      <button class="btn" id="cookie-accept" type="button">Accept</button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'cam-cookie-consent';
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  // Only ever called after the visitor has accepted (either just now, or on
  // a prior visit). No AdSense or ad-related script may load outside of
  // this function, so a Reject choice (or no choice yet) never sets an ad
  // cookie or fires an ad request.
  function loadAdsScripts() {
    // AdSense has not been approved yet, so there is nothing to load. Once
    // approved, insert the real ad script here, e.g.:
    //
    // const script = document.createElement('script');
    // script.async = true;
    // script.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX';
    // script.crossOrigin = 'anonymous';
    // document.head.appendChild(script);
  }

  function applyConsent(value) {
    localStorage.setItem(STORAGE_KEY, value);
    if (banner) banner.hidden = true;
    if (value === 'accepted') loadAdsScripts();
  }

  const storedConsent = localStorage.getItem(STORAGE_KEY);
  if (!storedConsent) {
    if (banner) banner.hidden = false;
  } else if (storedConsent === 'accepted') {
    loadAdsScripts();
  }

  acceptBtn?.addEventListener('click', () => applyConsent('accepted'));
  rejectBtn?.addEventListener('click', () => applyConsent('rejected'));
</script>
