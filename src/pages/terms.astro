---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Terms | Calc and Measure';
const description = 'Terms of use for Calc and Measure, covering accuracy, acceptable use, and liability.';
const path = '/terms';
const lastUpdated = 'July 7, 2026';

const schema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://calcandmeasure.com' },
    { '@type': 'ListItem', position: 2, name: 'Terms', item: 'https://calcandmeasure.com/terms' },
  ],
};
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="sep">&gt;</span>
    <span aria-current="page">Terms</span>
  </nav>

  <h1>Terms of Use</h1>
  <p class="disclaimer">Last updated: {lastUpdated}</p>

  <p>
    By using Calc and Measure, you agree to the terms below. If you do not agree with them,
    please do not use the site.
  </p>

  <h2>Use of the Tools</h2>
  <p>
    The calculators and converters on this site are provided for general informational and
    reference purposes. They are free to use, and no account or payment is required.
  </p>

  <h2>Accuracy</h2>
  <p>
    We aim for every formula and reference table on this site to be correct and to use widely
    accepted standard values. Even so, results are provided "as is" without any guarantee of
    accuracy for a specific purpose. Reference tables for things like shoe sizes, ring sizes,
    and clothing sizes are general guides, not brand-specific charts, and real-world values can
    vary. Do not rely on this site as the sole basis for medical, legal, financial, academic, or
    safety-related decisions. When a decision matters, verify important figures independently
    or consult a qualified professional.
  </p>

  <h2>No Warranty</h2>
  <p>
    This site is provided without warranties of any kind, whether express or implied, including
    warranties of accuracy, reliability, or fitness for a particular purpose.
  </p>

  <h2>Limitation of Liability</h2>
  <p>
    To the fullest extent permitted by law, Calc and Measure is not liable for any loss or
    damage arising from your use of, or inability to use, this site or the information it
    provides.
  </p>

  <h2>Acceptable Use</h2>
  <p>
    You agree not to misuse the site, including attempting to disrupt its normal operation,
    scraping it at a scale that degrades service for other visitors, or using it for any
    unlawful purpose.
  </p>

  <h2>Advertising</h2>
  <p>
    This site is supported by advertising, including Google AdSense. Ads are clearly labeled
    and separated from the tools and written content on each page. See the
    <a href="/privacy-policy">Privacy Policy</a> for details on cookies and data use related to
    advertising.
  </p>

  <h2>Changes to These Terms</h2>
  <p>
    These terms may be updated from time to time. Continued use of the site after a change
    means you accept the updated terms.
  </p>

  <h2>Contact</h2>
  <p>
    Questions about these terms can be sent to
    <a href="mailto:contact@calcandmeasure.com">contact@calcandmeasure.com</a>.
  </p>
</BaseLayout>
